rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Current app-compatible rules:
    // - Browser can read chat threads/messages for real-time updates.
    // - Browser cannot write anything.
    // - All writes must go through your Next.js API (Firebase Admin SDK).
    match /chatThreads/{threadId} {
      allow read: if true;
      allow write: if false;

      match /messages/{messageId} {
        allow read: if true;
        allow write: if false;
      }
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

